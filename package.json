{
  "name": "react-cosmos-dark-mode",
  "version": "0.1.3",
  "description": "React Cosmos plugin for toggling dark mode",
  "repository": "https://github.com/birchill/react-cosmos-dark-mode/",
  "author": "Birchill, Inc.",
  "license": "MIT",
  "main": "./cosmos.plugin.json",
  "exports": {
    ".": "./cosmos.plugin.json",
    "./DarkMode": {
      "import": "./dist/DarkMode.js",
      "require": "./dist/DarkMode.cjs"
    }
  },
  "files": [
    "DarkMode/**",
    "dist/**",
    "cosmos.plugin.json"
  ],
  "type": "module",
  "devDependencies": {
    "@release-it/conventional-changelog": "11.0.1",
    "@rollup/plugin-virtual": "3.0.2",
    "@types/react": "19.2.17",
    "react": "19.2.7",
    "react-cosmos": "7.3.0",
    "react-cosmos-ui": "7.3.0",
    "react-plugin": "3.0.0-alpha.4",
    "release-it": "20.2.0",
    "styled-components": "6.4.2",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  },
  "prettier": {
    "bracketSpacing": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "engines": {}
  },
  "engines": {
    "pnpm": ">=11"
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsdown",
    "release": "release-it"
  },
  "peerDependencies": {
    "react-cosmos": "^7.1.0"
  }
}
